# ── 화성복지플랫폼 프록시 환경변수 ──────────────────────────
# 공공데이터포털(data.go.kr)에서 발급받은 "일반 인증키(Decoding)"
# 값을 넣으면 실시간 API를 호출합니다. 비워두면 검증된 공식 정적값을 반환합니다.
DATA_GO_KR_KEY=

# 주민등록 인구 API 엔드포인트 (예시 — 실제 신청한 데이터셋 URL로 교체)
#   예) 행정안전부_지역별(읍면동) 성별 연령별 주민등록 인구수
POP_API_URL=https://api.odcloud.kr/api/15118049/v1/uddi:REPLACE-WITH-YOUR-UDDI

# 조회 대상 행정구역 (법정동/행정동 코드 또는 명칭 — 데이터셋 스펙에 맞게)
UJEONG_NAME=우정읍
JANGAN_NAME=장안면

# (선택) KOSIS OpenAPI — 전국 시도별 통계 실시간 조회용
#   1) https://kosis.kr/openapi 회원가입 → 활용신청 → 인증키 발급
#   2) 각 통계표 페이지에서 [OpenAPI] → 'URL 생성'으로 완성 URL을 만들어
#      (apiKey·objL1=ALL·시도·format=json 포함) 아래에 통째로 붙여넣기.
#   비워두면 번들된 공식 통계를 그대로 사용합니다.
#   붙여넣기 후 http://localhost:8787/api/kosis-test?url=<URL> 로 즉시 검증 가능.
KOSIS_SENIOR_URL=
KOSIS_DAYCARE_URL=
KOSIS_DISABLED_URL=

# 서버 포트
PORT=8787

# 캐시 유효시간(초) — 공공데이터는 월 단위 갱신이므로 길게 두어도 무방
CACHE_TTL=86400
